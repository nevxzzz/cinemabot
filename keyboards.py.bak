"""
Módulo de teclados inline — centraliza todos os InlineKeyboardMarkup do bot.
Players: WarezCDN e SuperflixAPI (via Mini App do Telegram).
"""

import urllib.parse
from pyrogram.types import InlineKeyboardMarkup, InlineKeyboardButton, WebAppInfo

from services.players import warezcdn_url, superflix_url

_CB_MAX = 64

# ⚠️  Cole aqui a URL onde você hospedou o player.html
# Opção gratuita: arraste o arquivo em https://app.netlify.com/drop
PLAYER_BASE_URL = "https://SEU_DOMINIO_AQUI/player.html"


def _player_web_app(
    tmdb_id: int,
    media_type: str,
    title: str = "",
    season: int = 0,
    episode: int = 0,
) -> WebAppInfo:
    """
    Constrói o WebAppInfo para abrir o player.html como Mini App do Telegram.
    O HTML recebe os parâmetros via query string e carrega o embed correto.
    """
    title_enc = urllib.parse.quote(title)
    tipo = "tv" if media_type == "tv" else "movie"

    if media_type == "tv":
        s = season or 1
        e = episode or 1
        url = f"{PLAYER_BASE_URL}?type={tipo}&id={tmdb_id}&s={s}&e={e}&title={title_enc}"
    else:
        url = f"{PLAYER_BASE_URL}?type={tipo}&id={tmdb_id}&title={title_enc}"

    return WebAppInfo(url=url)


# ─────────────────────────── Teclados ───────────────────────────────

def start_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton("🎬 Filmes Populares", callback_data="trending:movie"),
            InlineKeyboardButton("📺 Séries em Alta",   callback_data="trending:tv"),
        ],
        [
            InlineKeyboardButton("🔥 Tudo em Alta", callback_data="trending:all"),
            InlineKeyboardButton("ℹ️ Como usar",    callback_data="help"),
        ],
    ])


def search_result_keyboard(results: list) -> InlineKeyboardMarkup:
    buttons = []
    for r in results:
        emoji    = "📺" if r.is_series else "🎬"
        label    = f"{emoji} {r.title} ({r.release_year})"
        callback = f"detail:{r.media_type}:{r.id}"
        buttons.append([InlineKeyboardButton(label, callback_data=callback)])
    buttons.append([InlineKeyboardButton("🏠 Início", callback_data="start")])
    return InlineKeyboardMarkup(buttons)


def media_detail_keyboard(media_id: int, media_type: str, title: str = "") -> InlineKeyboardMarkup:
    """Teclado para detalhes de filme — abre Mini App do player."""
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton(
                "▶️ Assistir Online",
                web_app=_player_web_app(media_id, media_type, title),
            ),
        ],
        [
            InlineKeyboardButton("🔙 Voltar aos resultados", callback_data="back_results"),
            InlineKeyboardButton("🏠 Início",                callback_data="start"),
        ],
    ])


def series_detail_keyboard(tv_id: int, title: str = "") -> InlineKeyboardMarkup:
    """Teclado para detalhes de série — abre Mini App e permite navegar temporadas."""
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton(
                "▶️ Assistir Online",
                web_app=_player_web_app(tv_id, "tv", title, season=1, episode=1),
            ),
        ],
        [
            InlineKeyboardButton("📋 Ver Temporadas", callback_data=f"seasons:{tv_id}"),
        ],
        [
            InlineKeyboardButton("🔙 Voltar aos resultados", callback_data="back_results"),
            InlineKeyboardButton("🏠 Início",                callback_data="start"),
        ],
    ])


def ep_detail_keyboard(
    tv_id: int,
    season_number: int,
    episode_number: int = 1,
    title: str = "",
) -> InlineKeyboardMarkup:
    """Teclado do detalhe de episódio — abre Mini App no episódio correto."""
    return InlineKeyboardMarkup([
        [
            InlineKeyboardButton(
                "▶️ Assistir Episódio",
                web_app=_player_web_app(tv_id, "tv", title, season=season_number, episode=episode_number),
            ),
        ],
        [
            InlineKeyboardButton("🔙 Episódios",  callback_data=f"eps:{tv_id}:{season_number}"),
            InlineKeyboardButton("📋 Temporadas", callback_data=f"seasons:{tv_id}"),
        ],
    ])


def seasons_keyboard(tv_id: int, seasons: list) -> InlineKeyboardMarkup:
    buttons = []
    for season in seasons:
        label = f"📺 T{season.season_number} — {season.name} ({season.episode_count} eps)"
        cb    = f"eps:{tv_id}:{season.season_number}"
        buttons.append([InlineKeyboardButton(label, callback_data=cb)])
    buttons.append([InlineKeyboardButton("🔙 Voltar à série", callback_data=f"detail:tv:{tv_id}")])
    return InlineKeyboardMarkup(buttons)


def episodes_keyboard(
    tv_id: int,
    season_number: int,
    episodes: list,
    page: int = 1,
) -> InlineKeyboardMarkup:
    PAGE_SIZE   = 8
    total_pages = max(1, (len(episodes) + PAGE_SIZE - 1) // PAGE_SIZE)
    page        = max(1, min(page, total_pages))
    start       = (page - 1) * PAGE_SIZE
    chunk       = episodes[start : start + PAGE_SIZE]

    buttons = []
    for ep in chunk:
        runtime = f" · {ep.runtime}min" if ep.runtime else ""
        label   = f"E{ep.episode_number:02d} — {ep.name}{runtime}"
        if len(label) > 40:
            label = label[:38] + "…"
        cb = f"ep_detail:{tv_id}:{season_number}:{ep.episode_number}"
        buttons.append([InlineKeyboardButton(label, callback_data=cb)])

    nav = []
    if page > 1:
        nav.append(InlineKeyboardButton("◀️", callback_data=f"eps_page:{tv_id}:{season_number}:{page-1}"))
    if total_pages > 1:
        nav.append(InlineKeyboardButton(f"📄 {page}/{total_pages}", callback_data="noop"))
    if page < total_pages:
        nav.append(InlineKeyboardButton("▶️", callback_data=f"eps_page:{tv_id}:{season_number}:{page+1}"))
    if nav:
        buttons.append(nav)

    buttons.append([InlineKeyboardButton("🔙 Temporadas", callback_data=f"seasons:{tv_id}")])
    return InlineKeyboardMarkup(buttons)


def trending_keyboard(results: list, media_type: str, page: int = 1) -> InlineKeyboardMarkup:
    PAGE_SIZE   = 8
    total_pages = max(1, (len(results) + PAGE_SIZE - 1) // PAGE_SIZE)
    page        = max(1, min(page, total_pages))
    start       = (page - 1) * PAGE_SIZE
    chunk       = results[start : start + PAGE_SIZE]

    buttons = []
    for r in chunk:
        emoji = "📺" if r.is_series else "🎬"
        label = f"{emoji} {r.title} ({r.release_year})"
        if len(label) > 40:
            label = label[:38] + "…"
        buttons.append([InlineKeyboardButton(label, callback_data=f"detail:{r.media_type}:{r.id}")])

    nav = []
    if page > 1:
        nav.append(InlineKeyboardButton("◀️", callback_data=f"trending_page:{media_type}:{page-1}"))
    if total_pages > 1:
        nav.append(InlineKeyboardButton(f"📄 {page}/{total_pages}", callback_data="noop"))
    if page < total_pages:
        nav.append(InlineKeyboardButton("▶️", callback_data=f"trending_page:{media_type}:{page+1}"))
    if nav:
        buttons.append(nav)

    buttons.append([InlineKeyboardButton("🏠 Início", callback_data="start")])
    return InlineKeyboardMarkup(buttons)


def back_to_start_keyboard() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("🏠 Início", callback_data="start")]
    ])
