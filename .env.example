# ─── Telegram ───────────────────────────────────
# Token do BotFather
BOT_TOKEN=seu_token_aqui

# Credenciais do app Telegram (https://my.telegram.org/apps)
API_ID=123456
API_HASH=sua_api_hash_aqui

# Seu ID numérico do Telegram (use @userinfobot para descobrir)
# Necessário para usar /admin, /broadcast e /clearcache
ADMIN_ID=0

# ─── TMDB ───────────────────────────────────────
# Chave da API (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=sua_chave_tmdb_aqui
